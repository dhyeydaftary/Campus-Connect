# ── Flask core ─────────────────────────────────────────────────
# Generate: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=your-secret-key-here

# Generate: python -c "import secrets; print(secrets.token_hex(16))"
SECURITY_PASSWORD_SALT=your-salt-here

# 1 for local dev only. NEVER 1 in production.
FLASK_DEBUG=1

# ── Database ───────────────────────────────────────────────────
# Local: sqlite:///campus_connect.db
# Production: your PostgreSQL URL (use postgresql://, not postgres://)
DATABASE_URL=sqlite:///campus_connect.db

# ── App URL ────────────────────────────────────────────────────
# Used to build password reset links in emails.
FRONTEND_URL=http://localhost:5000

# ── Email / SMTP ───────────────────────────────────────────────
MAIL_SERVER=smtp.gmail.com
MAIL_PORT=587
MAIL_USE_TLS=true
MAIL_USERNAME=your-email@gmail.com
MAIL_PASSWORD=your-gmail-app-password

# ── Rate Limiter ───────────────────────────────────────────────
# Leave empty locally. Set to Redis URL in production.
# REDIS_URL=redis://localhost:6379/0

# ── Cookie / Security ──────────────────────────────────────────
# Set false locally (HTTP). True in production (HTTPS only).
SESSION_COOKIE_SECURE=false

# ── Logging ────────────────────────────────────────────────────
# Required for logs to stream in real-time on Heroku/Render.
PYTHONUNBUFFERED=1